{
  "name": "@wikibase/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./embeddings": {
      "import": "./dist/embeddings.js",
      "default": "./dist/embeddings.js",
      "types": "./dist/embeddings.d.ts"
    },
    "./blocks": {
      "import": "./dist/blockQueries.js",
      "default": "./dist/blockQueries.js",
      "types": "./dist/blockQueries.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/config.ts src/client.ts src/queries.ts src/schema.ts --format esm --outDir dist --dts --external drizzle-orm --external postgres && tsup src/embeddings.ts --format esm --outDir dist --dts --external @huggingface/transformers && tsup src/blockQueries.ts --format esm --outDir dist --dts --external drizzle-orm --external postgres --external @huggingface/transformers",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "drizzle-kit": "^0.30.4",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
